# ── Required API Keys ─────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# Polygon.io — fundamentals, price history, financials
# Get at: https://polygon.io/dashboard
POLYGON_API_KEY=your_key_here

# Anthropic — AI thesis generation (Claude Sonnet)
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Notion — sync watchlist to Notion database (optional)
# Get at: https://www.notion.so/my-integrations
NOTION_TOKEN=your_token_here
NOTION_DATABASE_ID=your_db_id_here
